#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<EOF
Usage: hdf5hist <file.h5>

Interactive CLI for browsing and visualizing FHist.jl histograms in HDF5 files.

Commands inside the shell:
  pwd              Print current path
  ls [path]        List directory contents
  cd [path]        Change directory
  tree [path]      Show directory tree
  info <path>      Show histogram metadata and statistics
  draw <path>      Draw histogram in browser (requires ROOT)
  exit             Exit the shell
EOF
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

case "$1" in
    -h|--help)
        usage
        exit 0
        ;;
esac

exec uv run --project "$SCRIPT_DIR" python "$SCRIPT_DIR/main.py" "$@"
